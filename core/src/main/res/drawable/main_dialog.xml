<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/main_gradient_start"
                android:centerColor="@color/main_gradient_center"
                android:endColor="@color/main_gradient_end" />
            <padding
                android:left="@dimen/dp_1"
                android:right="@dimen/dp_1"
                android:top="@dimen/dp_1"
                android:bottom="@dimen/dp_1" />
            <corners android:radius="@dimen/dp_24" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/secondary_gradient_start"
                android:centerColor="@color/secondary_gradient_center"
                android:endColor="@color/secondary_gradient_end" />
            <padding
                android:left="@dimen/dp_1"
                android:right="@dimen/dp_1"
                android:top="@dimen/dp_1"
                android:bottom="@dimen/dp_1" />
            <corners android:radius="@dimen/dp_24" />
        </shape>
    </item>
</layer-list>